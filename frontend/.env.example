# Copy to .env.local (never commit .env.local). These are server-only — do not prefix with NEXT_PUBLIC_.

# Full URL of the n8n webhook (e.g. https://your-host/webhook/meme-agent-input)
N8N_WEBHOOK_URL=

# Optional shared secret: sent as X-Webhook-Secret on server-to-n8n requests.
# Configure your n8n Webhook node to require this header before processing.
MEME_WEBHOOK_SECRET=
