      "name": "Fetch Reddit RSS"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst trends = [];\n\nfor (const item of items) {\n  const content = item.json.data || '';\n  \n  // Google Trends uses <title> directly\n  // Reddit uses <title><![CDATA[...]]></title>\n  const titleMatches = content.match(\n    /<title><!\\[CDATA\\[(.*?)\\]\\]><\\/title>|<title>([^<]{10,})<\\/title>/g\n  ) || [];\n  \n  titleMatches.forEach(match => {\n    const title = match\n      .replace(/<title><!\\[CDATA\\[/, '')\n      .replace(/\\]\\]><\\/title>/, '')\n      .replace(/<title>/, '')\n      .replace(/<\\/title>/, '')\n      .trim();\n    \n    const skipWords = ['reddit', 'memes', 'dankmemes', 'outoftheloop', \n                       'google', 'trending', 'rss', 'news'];\n    const shouldSkip = skipWords.some(w => title.toLowerCase().includes(w));\n    \n    if (title.length > 10 && !shouldSkip) {\n      trends.push({\n        text:      title,\n        source:    content.includes('google') ? 'google_trends' : 'reddit',\n        timestamp: new Date().toISOString()\n      });\n    }\n  });\n}\n\nconst unique = [...new Map(trends.map(t => [t.text, t])).values()];\nconsole.log(`Parsed ${unique.length} unique trends`);\n\nreturn unique.slice(0, 30).map(t => ({ json: t }));"
      },
      "type": "n8n-nodes-base.code",
