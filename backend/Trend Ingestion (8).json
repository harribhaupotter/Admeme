    {
      "parameters": {
        "jsCode": "// Get embedding from Cohere response\nconst embedding = $input.first().json.embeddings?.float?.[0];\n\n// Get original template from the loop's current item\nconst loopItems = $('Loop Over Items').first().json;\nconst name      = loopItems.name      || '';\nconst image_url = loopItems.image_url || '';\nconst source    = loopItems.source    || 'reddit_template';\nconst timestamp = loopItems.timestamp || new Date().toISOString();\n\nif (!name) {\n  return [{ json: { error: 'no name found', raw: loopItems } }];\n}\n\nconst id = Math.abs(\n  name.split('').reduce((a, c) => Math.imul(31, a) + c.charCodeAt(0) | 0, 0)\n);\n\nreturn [{\n  json: {\n    points: [{\n      id:     id,\n      vector: embedding,\n      payload: { name, image_url, source, timestamp }\n    }]\n  }\n}];"
      },
