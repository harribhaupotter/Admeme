      "name": "Fetch_Template_RSS"
    },
    {
      "parameters": {
        "jsCode": "const content = $input.first().json.data || '';\nconst entries = content.match(/<entry>[\\s\\S]*?<\\/entry>/g) || [];\n\nconst templates = [];\n\nfor (const entry of entries) {\n  // Get title\n  const titleMatch = entry.match(/<title[^>]*><!\\[CDATA\\[(.*?)\\]\\]><\\/title>|<title[^>]*>([^<]+)<\\/title>/);\n  let title = titleMatch ? (titleMatch[1] || titleMatch[2] || '').trim() : '';\n  \n  // Clean HTML entities from title\n  title = title\n    .replace(/&quot;/g, '\"')\n    .replace(/&amp;/g, '&')\n    .replace(/&lt;/g, '<')\n    .replace(/&gt;/g, '>')\n    .replace(/&#39;/g, \"'\")\n    .trim();\n\n  // Get clean image URL - stop at first quote/space/bracket after URL\n  const redditImgMatch = entry.match(/https:\\/\\/i\\.redd\\.it\\/([a-zA-Z0-9_-]+)\\.(jpg|jpeg|png|gif|webp)/i);\n  const previewMatch   = entry.match(/https:\\/\\/preview\\.redd\\.it\\/([a-zA-Z0-9_\\-.%]+)\\.(jpg|jpeg|png|gif|webp)/i);\n  const externalMatch  = entry.match(/https:\\/\\/external-preview\\.redd\\.it\\/([a-zA-Z0-9_\\-.%]+)\\.(jpg|jpeg|png|gif|webp)/i);\n\n  let imageUrl = '';\n  if (redditImgMatch)   imageUrl = `https://i.redd.it/${redditImgMatch[1]}.${redditImgMatch[2]}`;\n  else if (previewMatch) imageUrl = `https://preview.redd.it/${previewMatch[1]}.${previewMatch[2]}`;\n  else if (externalMatch) imageUrl = `https://external-preview.redd.it/${externalMatch[1]}.${externalMatch[2]}`;\n\n  if (title && title.length > 3) {\n    templates.push({\n      name:      title,\n      image_url: imageUrl || '',\n      source:    'reddit_template',\n      timestamp: new Date().toISOString()\n    });\n  }\n}\n\nreturn templates.slice(0, 10).map(t => ({ json: t }));"
      },
      "type": "n8n-nodes-base.code",
