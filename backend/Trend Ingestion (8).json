    {
      "parameters": {
        "jsCode": "const embedding = $input.first().json.embeddings.float[0];\nconst trend = $('Parse_Trends_RAG').item.json;\n\nconst id = Math.abs(\n  trend.text.split('').reduce((a, c) => Math.imul(31, a) + c.charCodeAt(0) | 0, 0)\n);\n\nreturn [{\n  json: {\n    points: [{\n      id: id,\n      vector: embedding,\n      payload: {\n        text:      trend.text,\n        source:    trend.source,\n        timestamp: trend.timestamp\n      }\n    }]\n  }\n}];"
      },
